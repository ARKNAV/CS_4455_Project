  m_Name: 
  m_EditorClassIdentifier: 
  objectiveSteps:
  - id: crouch
    text: 'Objective: Crouch behind the large crate.\n[Left Ctrl / C] to crouch'
  - id: peek
    text: 'Objective: Peek around the corner. Do not get caught.\n[Q] peek left 
      [E] peek right'
  - id: takedown
    text: 'Objective: Press ''F'' to take down the dock worker.'
  - id: disguise
    text: 'Objective: Swap into a disguise.\n[F] near a disguise box to equip'
  - id: idcard
    text: 'Objective: Retrieve the Dock Supervisor ID Card from the locker.\n[F]
      to interact'
  - id: exit
    text: 'Objective: Use the ID Card on the main door.\n[F] on the keycard reader'
  - id: stability_signature
    text: 'Objective: Synchronize Reactor Core Diagnostics'
  - id: collect_center_key_1
    text: 'Objective: Collect key 1 for the center console'
  - id: collect_center_key_2
    text: 'Objective: Collect key 2 for the center console'
  - id: collect_blueprints
    text: 'Objective: Use the center console to secure the blueprints'
  playerInput: {fileID: 66678672}
